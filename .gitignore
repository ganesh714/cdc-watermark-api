# Ignore environment variables
.env

# JVM crash logs and temp files
hs_err_pid*.log
replay_pid*.log
*.log
*.txt
!README.md

# Ignore export outputs
output/*
!output/.gitignore
*.csv

# Ignore standard Java/Spring Boot build folders (for later)
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
### STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### IntelliJ IDEA ###
.idea
*.iws
*.iml
*.ipr

### NetBeans ###
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/